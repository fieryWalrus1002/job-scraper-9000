# Copy to .env and fill in your values — never commit .env
HOME_LOCATION="<your home location here, e.g. 'Seattle, WA'>"
USER_TIMEZONE="<your time zone here>"

# OpenAI API key — required when llm.provider=openai in config/ci/pr_summarizer.yml
OPENAI_API_KEY="<your OpenAI API key here>"
OPENAI_API_KEY_SKILLS_FIT="<your OpenAI API key for skills_fit here>"

# Read-only admin key for OpenAI API to query cost data
OPENAI_ADMIN_KEY="<your OpenAI read-only admin key here>"
