# Copy to .env and fill in your values — never commit .env
HOME_LOCATION="Hometown, WA"

# OpenAI API key — used by the remote-filter agent when LLM_PROVIDER=openai
OPENAI_API_KEY="sk-..."

# LLM provider for agents: "openai" (default) or "ollama" (local, no cost)
LLM_PROVIDER="openai"

# Model override — defaults to gpt-4o-mini (openai) or qwen2.5:14b (ollama)
# LLM_MODEL="gpt-4o-mini"

# Ollama base URL — only needed when LLM_PROVIDER=ollama
# OLLAMA_BASE_URL="http://localhost:11434/v1"
