# Copy to .env and fill in your values — never commit .env

# Postgres connection string
# Local dev (Docker Compose):  postgresql://jobscraper:jobscraper@localhost:5432/jobscraper
# Azure Database for PostgreSQL: postgresql://user:pass@host.postgres.database.azure.com:5432/jobscraper?sslmode=require
DATABASE_URL="postgresql://jobscraper:jobscraper@localhost:5432/jobscraper"

HOME_LOCATION="<your home location here, e.g. 'Seattle, WA'>"
USER_TIMEZONE="<your time zone here>"

# OpenAI API key — required when llm.provider=openai in config/ci/pr_summarizer.yml
OPENAI_API_KEY="<your OpenAI API key here>"
OPENAI_API_KEY_SKILLS_FIT="<your OpenAI API key for skills_fit here>"

# Read-only admin key for OpenAI API to query cost data
OPENAI_ADMIN_KEY="<your OpenAI read-only admin key here>"

# Backend auth bypass for local development
# Set to 1 to skip Entra ID auth (returns a stub principal).
# Never set this in production. This is purely for the backend.
AUTH_BYPASS=0

# Makes it easier to manage the ACR name and login server in one place.
ACR_NAME="<your Azure Container Registry name here>"
ACR_LOGIN_SERVER="${ACR_NAME}.azurecr.io"

AZURE_STORAGE_ACCOUNT="<your Azure Storage Account name here>"
