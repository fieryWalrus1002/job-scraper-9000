# Python / FastAPI backend
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
coverage.xml
htmlcov/

# TypeScript / React / Vite frontend
node_modules/
frontend/node_modules/
dist/
frontend/dist/
frontend/dist-ssr/
frontend/.vite/
frontend/.vite-temp/
*.tsbuildinfo

# Logs and local env
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.env
.env.*
*.local
!.env.example
!**/.env.example

# Docker local overrides
docker-compose.override.yml

# Editors / OS
.vscode/
.idea/
.DS_Store

# Data files — keep directory placeholders (.gitkeep) but ignore all content
data/**/*.jsonl
data/**/*.txt
data/**/*.md
data/**/*.json
data/**/*.csv
!data/**/.gitkeep
!data/**/README.md

# ephemeral CI artifacts generated by pr-summarizer workflow
context.md
ai_response.txt

# local stuff I don't want to commit
notes/
logs/
handoffs/

# Configs with PII

# known failures don't need to be tracked in git
config/known_failures.json

# Candidate profiles contain PII (name, employer, comp, etc.). The
# .example template is the only profile YAML that should be tracked.
config/profile/*.yml
config/profile/old_profiles/*.yml
!config/profile/*.yml.example
config/profile/CHANGELOG.md

# Search configs have some PII
config/search*.yml
config/search.yml
config/old_searches/*.yml
!config/search*.yml.example
config/job*.yml

# Auth config contains personal email address
config/auth.yml
!config/auth.yml.example
frontend/openapi.json

# Infra configs with PII (Azure Object IDs, etc.)
infra/*.bicepparam
infra/*.json

# Pipeline run artifacts (planner/worker/scoring) and materialized per-user
# configs (pull_user_configs.py) — contain personal profile data in .yml that
# the data/**/* globs above don't catch. Regenerated from the DB, never committed.
data/pipeline_runs/
data/user_configs/
data/run_telemetry/
# Legacy pre-Phase-15 location (now data/pipeline_runs/ + data/user_configs/);
# kept ignored so stale local artifacts here are never committed.
runs/
