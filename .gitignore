.venv/
__pycache__/
*.py[cod]
*.egg-info/
dist/
.env

# Data files — keep directory placeholders (.gitkeep) but ignore all content
data/**/*.jsonl
data/**/*.txt
data/**/*.md
!data/README.md

# stray jsonl at the repo root
/*.jsonl

# known failures don't need to be tracked in git
config/known_failures.json

# Candidate profiles contain PII (name, employer, comp, etc.). The
# .example template is the only profile YAML that should be tracked.
config/profile/*.yml
!config/profile/*.yml.example

# IDE config — local only
.vscode/

# local stuff I don't want to commit
.deprecated/
.notes/
notes/
.logs/
.docs/
config/profile/old_profiles/*.yml
# ephemeral CI artifacts generated by pr-summarizer workflow
context.md
ai_response.txt

# issue templates that I paste to make issues, but don't want to track in git
issues/
